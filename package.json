{
  "name": "yasui",
  "version": "3.0.0",
  "description": "Lightweight framework for REST and web APIs",
  "license": "AGPL-3.0-or-later",
  "author": "Thomas BARKATS",
  "keywords": [
    "framework",
    "lightweight",
    "minimalist",
    "API",
    "REST",
    "typescript",
    "decorators",
    "dependency-injection",
    "middleware",
    "nodejs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thomasbarkats/yasui.git"
  },
  "homepage": "https://github.com/thomasbarkats/yasui#readme",
  "bugs": {
    "url": "https://github.com/thomasbarkats/yasui/issues"
  },
  "main": "./lib/index.js",
  "types": "./@types/index.d.ts",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "example": "nodemon",
    "build": "rm -rf lib && tsc && npm run flatten-lib && tsc-alias",
    "flatten-lib": "mv lib/src/* lib/ && rm -rf lib/src && mv lib/@types/* lib/ && rm -rf lib/@types",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint . --ext .ts --fix",
    "prepublishOnly": "npm run build && npm run lint",
    "preversion": "npm run lint",
    "precommit": "npm run lint",
    "commit": "npm run lint && format-commit"
  },
  "files": [
    "lib/**/*",
    "!lib/examples/**/*",
    "@types/**/*"
  ],
  "dependencies": {
    "kleur": "^4.1.5",
    "reflect-metadata": "^0.2.2",
    "srvx": "^0.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.27.0",
    "format-commit": "^0.3.1",
    "globals": "^16.2.0",
    "nodemon": "^3.1.10",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.3"
  }
}
